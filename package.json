{
  "name": "@ismail-elkorchi/terminal-ui",
  "version": "0.1.0",
  "description": "Runtime-agnostic terminal host, prompt, shell, widget, TUI, accessibility, and testing primitives.",
  "type": "module",
  "license": "MIT",
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./src/index.d.ts",
      "default": "./src/index.js"
    },
    "./host": {
      "types": "./src/host.d.ts",
      "default": "./src/host.js"
    },
    "./prompts": {
      "types": "./src/prompts.d.ts",
      "default": "./src/prompts.js"
    },
    "./shell": {
      "types": "./src/shell.d.ts",
      "default": "./src/shell.js"
    },
    "./tui": {
      "types": "./src/tui.d.ts",
      "default": "./src/tui.js"
    },
    "./widgets": {
      "types": "./src/widgets.d.ts",
      "default": "./src/widgets.js"
    },
    "./testing": {
      "types": "./src/testing.d.ts",
      "default": "./src/testing.js"
    }
  },
  "files": [
    "src",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "check": "node --test",
    "test": "node --test"
  },
  "keywords": [
    "terminal",
    "cli",
    "prompts",
    "tui",
    "accessibility",
    "testing"
  ]
}
