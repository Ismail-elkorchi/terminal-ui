{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.ismail-elkorchi.dev/terminal-ui/shell-transcript.schema.json",
  "type": "object",
  "required": ["schemaVersion", "id", "commands", "diagnostics"],
  "properties": {
    "schemaVersion": { "const": "terminal-ui.shell-transcript.v1" },
    "id": { "type": "string", "minLength": 1 },
    "startedAt": { "type": "string" },
    "commands": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["input", "status", "diagnostics"],
        "properties": {
          "input": { "type": "string" },
          "argv": { "type": "array", "items": { "type": "string" } },
          "status": { "enum": ["parsed", "validated", "completed", "failed", "skipped"] },
          "exitCode": { "type": "integer" },
          "diagnostics": {
            "type": "array",
            "items": { "$ref": "https://schemas.ismail-elkorchi.dev/terminal-ui/terminal-diagnostic.schema.json" }
          }
        },
        "additionalProperties": false
      }
    },
    "diagnostics": {
      "type": "array",
      "items": { "$ref": "https://schemas.ismail-elkorchi.dev/terminal-ui/terminal-diagnostic.schema.json" }
    }
  },
  "additionalProperties": false
}
