{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.ismail-elkorchi.dev/terminal-ui/tui-frame.schema.json",
  "type": "object",
  "required": ["schemaVersion", "width", "height", "cells", "accessibility"],
  "properties": {
    "schemaVersion": { "const": "terminal-ui.tui-frame.v1" },
    "width": { "type": "integer", "minimum": 0 },
    "height": { "type": "integer", "minimum": 0 },
    "cells": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["row", "column", "text", "width"],
        "properties": {
          "row": { "type": "integer", "minimum": 1 },
          "column": { "type": "integer", "minimum": 1 },
          "text": { "type": "string" },
          "width": { "type": "integer", "minimum": 0 },
          "style": { "$ref": "#/$defs/terminalStyle" },
          "link": { "$ref": "#/$defs/terminalLink" },
          "source": { "$ref": "#/$defs/frameCellSource" },
          "continuation": { "type": "boolean" }
        },
        "additionalProperties": false
      }
    },
    "hitTargets": {
      "type": "array",
      "items": { "$ref": "#/$defs/frameHitTarget" }
    },
    "cursor": {
      "type": "object",
      "required": ["row", "column"],
      "properties": {
        "row": { "type": "integer", "minimum": 1 },
        "column": { "type": "integer", "minimum": 1 }
      },
      "additionalProperties": false
    },
    "focusPath": { "type": "array", "items": { "type": "string" } },
    "accessibility": { "$ref": "https://schemas.ismail-elkorchi.dev/terminal-ui/accessible-snapshot.schema.json" }
  },
  "$defs": {
    "terminalStyle": {
      "type": "object",
      "properties": {
        "fg": { "$ref": "#/$defs/terminalColor" },
        "bg": { "$ref": "#/$defs/terminalColor" },
        "bold": { "type": "boolean" },
        "dim": { "type": "boolean" },
        "italic": { "type": "boolean" },
        "underline": { "type": "boolean" },
        "strikethrough": { "type": "boolean" },
        "inverse": { "type": "boolean" },
        "hidden": { "type": "boolean" }
      },
      "additionalProperties": false
    },
    "terminalColor": {
      "oneOf": [
        {
          "type": "object",
          "required": ["kind", "value"],
          "properties": {
            "kind": { "const": "ansi" },
            "value": { "type": "integer", "minimum": 0, "maximum": 255 }
          },
          "additionalProperties": false
        },
        {
          "type": "object",
          "required": ["kind", "r", "g", "b"],
          "properties": {
            "kind": { "const": "rgb" },
            "r": { "type": "integer", "minimum": 0, "maximum": 255 },
            "g": { "type": "integer", "minimum": 0, "maximum": 255 },
            "b": { "type": "integer", "minimum": 0, "maximum": 255 }
          },
          "additionalProperties": false
        },
        {
          "type": "object",
          "required": ["kind", "token"],
          "properties": {
            "kind": { "const": "theme" },
            "token": { "type": "string", "minLength": 1 }
          },
          "additionalProperties": false
        }
      ]
    },
    "terminalLink": {
      "type": "object",
      "required": ["href"],
      "properties": {
        "href": { "type": "string" },
        "id": { "type": "string" }
      },
      "additionalProperties": false
    },
    "frameCellSource": {
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "kind": { "type": "string" },
        "role": { "type": "string" },
        "label": { "type": "string" }
      },
      "additionalProperties": false
    },
    "frameHitTarget": {
      "type": "object",
      "required": ["id", "bounds"],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "bounds": { "$ref": "#/$defs/rect" },
        "cursor": { "enum": ["pointer", "text", "default"] },
        "zIndex": { "type": "integer" }
      },
      "additionalProperties": false
    },
    "rect": {
      "type": "object",
      "required": ["row", "column", "width", "height"],
      "properties": {
        "row": { "type": "integer", "minimum": 1 },
        "column": { "type": "integer", "minimum": 1 },
        "width": { "type": "integer", "minimum": 0 },
        "height": { "type": "integer", "minimum": 0 }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
